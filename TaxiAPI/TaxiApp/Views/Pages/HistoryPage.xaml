<UserControl x:Class="TaxiApp.Views.Pages.HistoryPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="#FFFFFF" CornerRadius="12" Padding="30" 
            BorderBrush="#E0E0E0" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="📋 История поездок" FontSize="24" FontWeight="Bold" 
                           Foreground="#212121"/>
                <TextBlock Text="Все ваши завершенные поездки" FontSize="14" 
                           Foreground="#757575" Margin="0,5,0,0"/>
            </StackPanel>

            <DataGrid Grid.Row="1" x:Name="TripsGrid" AutoGenerateColumns="False" 
                      IsReadOnly="True" CanUserAddRows="False" 
                      AlternatingRowBackground="#FAFAFA" 
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                      BorderThickness="0">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#FFF8E1"/>
                        <Setter Property="Foreground" Value="#212121"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Padding" Value="10,8"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Код заказа" Binding="{Binding Code}" Width="*"/>
                    <DataGridTextColumn Header="Дата" Binding="{Binding CreatedAt, StringFormat=dd.MM.yyyy HH:mm}" Width="1.5*"/>
                    <DataGridTextColumn Header="Откуда" Binding="{Binding PickupAddress}" Width="2*"/>
                    <DataGridTextColumn Header="Куда" Binding="{Binding DestinationAddress}" Width="2*"/>
                    <DataGridTextColumn Header="Стоимость" Binding="{Binding EstimatedCost, StringFormat={}{0} ₽}" Width="*"/>
                    <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Border>
</UserControl>