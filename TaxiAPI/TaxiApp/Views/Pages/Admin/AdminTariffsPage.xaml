<UserControl x:Class="TaxiApp.Views.Pages.Admin.AdminTariffsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#FFFFFF" CornerRadius="12" Padding="25" 
                BorderBrush="#E0E0E0" BorderThickness="1" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="💵 Управление тарифами" FontSize="26" FontWeight="Bold" Foreground="#212121"/>
                    <TextBlock Text="Добавление, редактирование и удаление тарифов" FontSize="14" Foreground="#757575" Margin="0,5,0,0"/>
                </StackPanel>

                <Button Grid.Column="1" Content="➕ Добавить тариф" Click="AddTariff_Click"
                        Background="#4CAF50" Foreground="White" FontSize="14" FontWeight="Bold" 
                        Padding="20,10" BorderThickness="0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- Форма редактирования -->
        <Border x:Name="EditPanel" Grid.Row="1" Background="#FFF8E1" CornerRadius="12" Padding="20" 
                BorderBrush="#FFC107" BorderThickness="1" Margin="0,0,0,15" Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="Название тарифа" FontSize="11" Foreground="#757575"/>
                    <TextBox x:Name="TariffName" Padding="10,8" BorderThickness="1" BorderBrush="#BDBDBD"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,10,0">
                    <TextBlock Text="Базовая цена (₽)" FontSize="11" Foreground="#757575"/>
                    <TextBox x:Name="TariffBasePrice" Padding="10,8" BorderThickness="1" BorderBrush="#BDBDBD"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="0,0,10,0">
                    <TextBlock Text="Цена за км (₽)" FontSize="11" Foreground="#757575"/>
                    <TextBox x:Name="TariffPricePerKm" Padding="10,8" BorderThickness="1" BorderBrush="#BDBDBD"/>
                </StackPanel>

                <Button Grid.Column="3" Content="💾 Сохранить" Click="SaveTariff_Click"
                        Background="#FFC107" Foreground="#212121" FontSize="14" FontWeight="Bold" 
                        Padding="15,8" BorderThickness="0" Cursor="Hand" Margin="0,17,5,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Grid.Column="4" Content="❌ Отмена" Click="CancelEdit_Click"
                        Background="#F5F5F5" Foreground="#424242" FontSize="14" 
                        Padding="15,8" BorderThickness="0" Cursor="Hand" Margin="0,17,0,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- Таблица тарифов -->
        <Border Grid.Row="2" Background="#FFFFFF" CornerRadius="12" Padding="20" 
                BorderBrush="#E0E0E0" BorderThickness="1">
            <DataGrid x:Name="TariffsGrid" AutoGenerateColumns="False" IsReadOnly="True" 
                      CanUserAddRows="False" AlternatingRowBackground="#FAFAFA" 
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal" BorderThickness="0">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#FFF8E1"/>
                        <Setter Property="Foreground" Value="#212121"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Padding" Value="12,10"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="*"/>
                    <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="2*"/>
                    <DataGridTextColumn Header="Базовая цена" Binding="{Binding BasePrice, StringFormat={}{0} ₽}" Width="*"/>
                    <DataGridTextColumn Header="Цена за км" Binding="{Binding PricePerKm, StringFormat={}{0} ₽}" Width="*"/>
                    <DataGridTextColumn Header="Создан" Binding="{Binding CreatedAt, StringFormat=dd.MM.yyyy HH:mm}" Width="1.5*"/>
                    <DataGridTemplateColumn Header="Действия" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="✏️" Click="EditTariff_Click" Tag="{Binding Id}"
                                            Background="#2196F3" Foreground="White" Padding="8,4" Margin="0,0,5,0"
                                            BorderThickness="0" Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <Button Content="🗑️" Click="DeleteTariff_Click" Tag="{Binding Id}"
                                            Background="#F44336" Foreground="White" Padding="8,4"
                                            BorderThickness="0" Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>