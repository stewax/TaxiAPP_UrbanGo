<UserControl x:Class="TaxiApp.Views.Pages.Admin.AdminTripsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок со статистикой -->
        <Border Grid.Row="0" Background="#FFFFFF" CornerRadius="12" Padding="25" 
                BorderBrush="#E0E0E0" BorderThickness="1" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="🚗 Управление поездками" FontSize="26" FontWeight="Bold" Foreground="#212121"/>
                    <TextBlock Text="История всех завершенных поездок" FontSize="14" Foreground="#757575" Margin="0,5,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Border Background="#E8F5E9" CornerRadius="10" Padding="20,15" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="💵 Общий доход" FontSize="11" Foreground="#757575"/>
                            <TextBlock x:Name="TotalIncomeText" Text="0 ₽" FontSize="22" FontWeight="Bold" Foreground="#2E7D32"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#FFF8E1" CornerRadius="10" Padding="20,15" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="🚗 Всего поездок" FontSize="11" Foreground="#757575"/>
                            <TextBlock x:Name="TotalTripsText" Text="0" FontSize="22" FontWeight="Bold" Foreground="#F57F17"/>
                        </StackPanel>
                    </Border>
                    <Button Content="🔄 Обновить" Click="Refresh_Click"
                            Background="#4CAF50" Foreground="White" FontSize="14" FontWeight="Bold" 
                            Padding="20,10" BorderThickness="0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Таблица поездок -->
        <Border Grid.Row="1" Background="#FFFFFF" CornerRadius="12" Padding="20" 
                BorderBrush="#E0E0E0" BorderThickness="1">
            <DataGrid x:Name="TripsGrid" AutoGenerateColumns="False" IsReadOnly="True" 
                      CanUserAddRows="False" AlternatingRowBackground="#FAFAFA" 
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal" BorderThickness="0">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#FFF8E1"/>
                        <Setter Property="Foreground" Value="#212121"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Padding" Value="12,10"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Код" Binding="{Binding Code}" Width="*"/>
                    <DataGridTextColumn Header="Клиент" Binding="{Binding ClientName}" Width="1.5*"/>
                    <DataGridTextColumn Header="Водитель" Binding="{Binding DriverName}" Width="1.5*"/>
                    <DataGridTextColumn Header="Расстояние" Binding="{Binding DistanceKm, StringFormat={}{0:F1} км}" Width="*"/>
                    <DataGridTextColumn Header="Время" Binding="{Binding DurationMinutes, StringFormat={}{0} мин}" Width="*"/>
                    <DataGridTextColumn Header="Стоимость" Binding="{Binding Price, StringFormat={}{0} ₽}" Width="*"/>
                    <DataGridTextColumn Header="Начало" Binding="{Binding StartTime, StringFormat=dd.MM.yyyy HH:mm}" Width="1.3*"/>
                    <DataGridTextColumn Header="Окончание" Binding="{Binding EndTime, StringFormat=dd.MM.yyyy HH:mm}" Width="1.3*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>