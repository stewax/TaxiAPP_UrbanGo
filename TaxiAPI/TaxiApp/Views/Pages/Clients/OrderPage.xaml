<UserControl x:Class="TaxiApp.Views.Pages.OrderPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Панель создания заказа -->
        <Border Grid.Column="0" Background="#FFFFFF" CornerRadius="12" Padding="25" 
                BorderBrush="#E0E0E0" BorderThickness="1" Margin="0,0,15,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="🗺 Создание заказа" FontSize="22" FontWeight="Bold" 
                               Foreground="#212121" Margin="0,0,0,20"/>

                    <!-- Точка подачи -->
                    <TextBlock Text="📍 Точка подачи" Foreground="#424242" Margin="0,0,0,6" FontWeight="SemiBold"/>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="PickupAddress" Grid.Column="0" 
                                 Padding="12,10" BorderThickness="1" BorderBrush="#BDBDBD" 
                                 Background="#FFFFFF" VerticalAlignment="Center"
                                 Text="Введите адрес подачи..."/>
                        <Button Grid.Column="1" Content="🔍" Width="40" Margin="5,0,0,0"
                                Click="FindPickup_Click"
                                Background="#FFC107" Foreground="#212121"
                                FontSize="16" FontWeight="Bold"
                                BorderThickness="0" Cursor="Hand"
                                ToolTip="Найти адрес">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                    <TextBlock x:Name="PickupCoords" Text="Координаты: -" 
                               FontSize="11" Foreground="#757575" Margin="0,0,0,15"/>

                    <!-- Точка назначения -->
                    <TextBlock Text="🎯 Точка назначения" Foreground="#424242" Margin="0,0,0,6" FontWeight="SemiBold"/>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="DestinationAddress" Grid.Column="0" 
                                 Padding="12,10" BorderThickness="1" BorderBrush="#BDBDBD" 
                                 Background="#FFFFFF" VerticalAlignment="Center"
                                 Text="Введите адрес назначения..."/>
                        <Button Grid.Column="1" Content="🔍" Width="40" Margin="5,0,0,0"
                                Click="FindDestination_Click"
                                Background="#FFC107" Foreground="#212121"
                                FontSize="16" FontWeight="Bold"
                                BorderThickness="0" Cursor="Hand"
                                ToolTip="Найти адрес">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                    <TextBlock x:Name="DestinationCoords" Text="Координаты: -" 
                               FontSize="11" Foreground="#757575" Margin="0,0,0,15"/>

                    <!-- Индикатор поиска -->
                    <Border x:Name="SearchIndicator" Background="#FFF8E1" CornerRadius="8" Padding="10" 
                            Margin="0,0,0,15" Visibility="Collapsed">
                        <TextBlock Text="🔍 Поиск адреса..." Foreground="#FF6F00" 
                                   HorizontalAlignment="Center"/>
                    </Border>

                    <!-- Тариф -->
                    <TextBlock Text="Тариф" Foreground="#424242" Margin="0,0,0,6" FontWeight="SemiBold"/>
                    <ComboBox x:Name="TariffSelect" 
          Padding="12,10" 
          BorderThickness="1" 
          BorderBrush="#BDBDBD" 
          Background="#FFFFFF" 
          Margin="0,0,0,15"
          SelectionChanged="TariffSelect_SelectionChanged"
          DisplayMemberPath="Name">
                        <!-- Элементы будут добавлены из API -->
                    </ComboBox>

                    <!-- Расчет стоимости -->
                    <Border Background="#FFF8E1" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="💰 Расчетная стоимость:" FontSize="12" Foreground="#757575"/>
                            <TextBlock x:Name="EstimatedCost" Text="0 ₽" FontSize="24" 
                                       FontWeight="Bold" Foreground="#FF6F00"/>
                            <TextBlock x:Name="DistanceText" Text="Расстояние: -" 
                                       FontSize="12" Foreground="#757575" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Кнопки -->
                    <Button Content="🚖 Заказать такси" 
                            Click="CreateOrder_Click"
                            Background="#FFC107" Foreground="#212121" 
                            FontSize="16" FontWeight="Bold" Padding="0,15" 
                            BorderThickness="0" Cursor="Hand" Margin="0,0,0,10">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Content="🔄 Сбросить маршрут" Click="ClearRoute_Click"
                            Background="#F5F5F5" Foreground="#424242" 
                            FontSize="14" Padding="0,10" BorderThickness="0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Карта -->
        <Border Grid.Column="1" Background="#FFFFFF" CornerRadius="12" 
                BorderBrush="#E0E0E0" BorderThickness="1" ClipToBounds="True">
            <wv2:WebView2 x:Name="MapView" />
        </Border>
    </Grid>
</UserControl>