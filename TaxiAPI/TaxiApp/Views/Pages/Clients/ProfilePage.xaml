<UserControl x:Class="TaxiApp.Views.Pages.ProfilePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="#FFFFFF" CornerRadius="12" Padding="30" 
            BorderBrush="#E0E0E0" BorderThickness="1">
        <StackPanel MaxWidth="500" HorizontalAlignment="Left">
            <TextBlock Text="👤 Мой профиль" FontSize="24" FontWeight="Bold" 
                       Foreground="#212121" Margin="0,0,0,20"/>

            <!-- ФИО -->
            <TextBlock Text="ФИО" Foreground="#424242" Margin="0,0,0,6" FontWeight="SemiBold"/>
            <!-- ❗ УБРАНА ВСЯКАЯ ПРИВЯЗКА Binding -->
            <TextBox x:Name="FullNameInput" Padding="12,10" BorderThickness="1" 
                     BorderBrush="#BDBDBD" Background="#FFFFFF" Margin="0,0,0,15"/>

            <!-- Телефон (только чтение) -->
            <TextBlock Text="Телефон" Foreground="#424242" Margin="0,0,0,6" FontWeight="SemiBold"/>
            <TextBox x:Name="PhoneInput" Padding="12,10" BorderThickness="1" 
                     BorderBrush="#BDBDBD" Background="#F5F5F5" Margin="0,0,0,15"
                     IsReadOnly="True" Foreground="#757575"/>

            <!-- Индикатор загрузки -->
            <ProgressBar x:Name="loadingIndicator" 
                         IsIndeterminate="True" Height="3" 
                         Foreground="#FFC107" Background="Transparent"
                         Margin="0,0,0,15" Visibility="Collapsed"/>

            <!-- Кнопка сохранения -->
            <Button Content="💾 Сохранить изменения" Click="Save_Click"
                    Background="#FFC107" Foreground="#212121" 
                    FontSize="15" FontWeight="Bold" Padding="0,12" 
                    BorderThickness="0" Cursor="Hand" Margin="0,10,0,0"
                    x:Name="saveButton">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Border>
</UserControl>