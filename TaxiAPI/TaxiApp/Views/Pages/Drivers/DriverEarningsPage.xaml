<UserControl x:Class="TaxiApp.Views.Pages.Drivers.DriverEarningsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок + Статистика -->
        <Border Grid.Row="0" Background="#FFFFFF" CornerRadius="12" Padding="25" 
                BorderBrush="#E0E0E0" BorderThickness="1" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Заголовок слева -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="💰 Мой доход" FontSize="26" FontWeight="Bold" 
                               Foreground="#212121"/>
                    <TextBlock Text="Статистика всех завершенных поездок" FontSize="14" 
                               Foreground="#757575" Margin="0,5,0,0"/>
                </StackPanel>

                <!-- Статистика справа -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <!-- Общий доход -->
                    <Border Background="#E8F5E9" CornerRadius="10" Padding="20,15" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="💵 Общий доход" FontSize="11" Foreground="#757575"/>
                            <TextBlock x:Name="TotalIncomeText" Text="0 ₽" FontSize="22" 
                                       FontWeight="Bold" Foreground="#2E7D32"/>
                        </StackPanel>
                    </Border>

                    <!-- Всего поездок -->
                    <Border Background="#FFF8E1" CornerRadius="10" Padding="20,15" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="🚗 Всего поездок" FontSize="11" Foreground="#757575"/>
                            <TextBlock x:Name="TotalTripsText" Text="0" FontSize="22" 
                                       FontWeight="Bold" Foreground="#F57F17"/>
                        </StackPanel>
                    </Border>

                    <!-- Общее расстояние -->
                    <Border Background="#E3F2FD" CornerRadius="10" Padding="20,15">
                        <StackPanel>
                            <TextBlock Text="📏 Общий пробег" FontSize="11" Foreground="#757575"/>
                            <TextBlock x:Name="TotalDistanceText" Text="0 км" FontSize="22" 
                                       FontWeight="Bold" Foreground="#1565C0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Фильтр по периоду -->
        <Border Grid.Row="1" Background="#FFFFFF" CornerRadius="12" Padding="20" 
                BorderBrush="#E0E0E0" BorderThickness="1" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="📅 Период:" FontSize="14" FontWeight="SemiBold" 
                           VerticalAlignment="Center" Margin="0,0,10,0"/>

                <StackPanel Grid.Column="1" Margin="0,0,10,0">
                    <TextBlock Text="С:" FontSize="11" Foreground="#757575"/>
                    <DatePicker x:Name="DateFrom" Width="150" Padding="8,5"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="0,0,10,0">
                    <TextBlock Text="По:" FontSize="11" Foreground="#757575"/>
                    <DatePicker x:Name="DateTo" Width="150" Padding="8,5"/>
                </StackPanel>

                <Button Grid.Column="3" Content="🔍 Применить" Click="ApplyFilter_Click"
                        Background="#FFC107" Foreground="#212121" 
                        FontSize="14" FontWeight="Bold" Padding="15,8" 
                        BorderThickness="0" Cursor="Hand" Margin="0,15,10,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Grid.Column="4" Content="🔄 Сбросить" Click="ResetFilter_Click"
                        Background="#F5F5F5" Foreground="#424242" 
                        FontSize="14" Padding="15,8" 
                        BorderThickness="0" Cursor="Hand" Margin="0,15,10,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Grid.Column="6" Content="🔄 Обновить" Click="Refresh_Click"
                        Background="#4CAF50" Foreground="White" 
                        FontSize="14" FontWeight="Bold" Padding="15,8" 
                        BorderThickness="0" Cursor="Hand" Margin="0,15,0,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- Таблица поездок -->
        <Border Grid.Row="2" Background="#FFFFFF" CornerRadius="12" Padding="20" 
                BorderBrush="#E0E0E0" BorderThickness="1">
            <DataGrid x:Name="TripsGrid" AutoGenerateColumns="False" 
                      IsReadOnly="True" CanUserAddRows="False" 
                      AlternatingRowBackground="#FAFAFA" 
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                      BorderThickness="0" FontSize="13">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#FFF8E1"/>
                        <Setter Property="Foreground" Value="#212121"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Padding" Value="12,10"/>
                        <Setter Property="BorderBrush" Value="#E0E0E0"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding" Value="10,8"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridCell">
                                    <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </DataGrid.CellStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Код поездки" Binding="{Binding Code}" Width="*"/>
                    <DataGridTextColumn Header="Клиент" Binding="{Binding ClientName}" Width="1.5*"/>
                    <DataGridTextColumn Header="Откуда" Binding="{Binding PickupAddress}" Width="2*"/>
                    <DataGridTextColumn Header="Куда" Binding="{Binding DestinationAddress}" Width="2*"/>
                    <DataGridTextColumn Header="Расстояние" Binding="{Binding DistanceKm, StringFormat={}{0:F1} км}" Width="*"/>
                    <DataGridTextColumn Header="Время" Binding="{Binding DurationMinutes, StringFormat={}{0} мин}" Width="*"/>
                    <DataGridTextColumn Header="Дата" Binding="{Binding EndTime, StringFormat=dd.MM.yyyy HH:mm}" Width="1.3*"/>
                    <DataGridTextColumn Header="Доход" Binding="{Binding Price, StringFormat={}{0} ₽}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Foreground" Value="#2E7D32"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>