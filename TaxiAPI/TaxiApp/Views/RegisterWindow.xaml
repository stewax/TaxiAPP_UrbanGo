<Window x:Class="TaxiApp.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TaxiApp.Views"
        mc:Ignorable="d"
        Title="RegisterWindow" Height="450" Width="800">
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#FFC107"/>
            <Setter Property="Foreground" Value="#212121"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFB300"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#FF8F00"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#E0E0E0"/>
                    <Setter Property="Foreground" Value="#9E9E9E"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="InputTextBox" TargetType="TextBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#BDBDBD"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#212121"/>
            <Setter Property="CaretBrush" Value="#212121"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" BorderThickness="{TemplateBinding BorderThickness}" BorderBrush="{TemplateBinding BorderBrush}">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="2" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#FFC107"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InputPasswordBox" TargetType="PasswordBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#BDBDBD"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#212121"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" BorderThickness="{TemplateBinding BorderThickness}" BorderBrush="{TemplateBinding BorderBrush}">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="2" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#FFC107"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Image Source="/Images/Bg_img.png" 
               Stretch="UniformToFill" 
               HorizontalAlignment="Center" 
               VerticalAlignment="Center"/>

        <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Width="340">
            <Border Background="#FFFFFF" 
                    CornerRadius="16" 
                    Padding="25,20"
                    BorderBrush="#E0E0E0"
                    BorderThickness="1"
                    >

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text=" Регистрация" 
                                   FontSize="24" 
                                   FontWeight="Bold" 
                                   Foreground="#212121"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,4"/>

                        <TextBlock Text="Создать аккаунт" 
                                   FontSize="14" 
                                   Foreground="#757575"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,15"/>

                        <TextBlock Text="ФИО" 
                                   Foreground="#424242" 
                                   Margin="0,0,0,4"
                                   FontSize="11"
                                   FontWeight="SemiBold"/>
                        <TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource InputTextBox}"
                                 Margin="0,0,0,12">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter" Command="{Binding RegisterCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>

                        <TextBlock Text="Телефон" 
                                   Foreground="#424242" 
                                   Margin="0,0,0,4"
                                   FontSize="11"
                                   FontWeight="SemiBold"/>
                        <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource InputTextBox}"
                                 Margin="0,0,0,12">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter" Command="{Binding RegisterCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>

                        <TextBlock Text="Пароль" 
                                   Foreground="#424242" 
                                   Margin="0,0,0,4"
                                   FontSize="11"
                                   FontWeight="SemiBold"/>
                        <PasswordBox x:Name="PasswordBox"
                                     Style="{StaticResource InputPasswordBox}"
                                     Margin="0,0,0,12"
                                     PasswordChanged="PasswordBox_PasswordChanged"/>

                        <TextBlock Text="Подтвердите пароль" 
                                   Foreground="#424242" 
                                   Margin="0,0,0,4"
                                   FontSize="11"
                                   FontWeight="SemiBold"/>
                        <PasswordBox x:Name="ConfirmPasswordBox"
                                     Style="{StaticResource InputPasswordBox}"
                                     Margin="0,0,0,12"
                                     PasswordChanged="ConfirmPasswordBox_PasswordChanged"/>

                        <TextBlock Text="{Binding ErrorMessage}" 
                                   Foreground="#D32F2F" 
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,10"
                                   Height="14"
                                   Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}"/>

                        <Button Content="Зарегистрироваться" 
                                Command="{Binding RegisterCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Margin="0,0,0,10"
                                Height="40"
                                IsEnabled="{Binding IsNotLoading}"/>

                        <ProgressBar IsIndeterminate="True" 
                                     Height="3"
                                     Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                                     Margin="0,0,0,10"
                                     Foreground="#FFC107"
                                     Background="Transparent"/>

                        <TextBlock HorizontalAlignment="Center">
                            <Run Text="Уже есть аккаунт? " Foreground="#757575"/>
                            <Hyperlink Foreground="#F57F17" 
                                      Command="{Binding LoginCommand}"
                                      TextDecorations="None">
                                <Run Text="Войти" FontWeight="SemiBold"/>
                            </Hyperlink>
                        </TextBlock>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Window>
