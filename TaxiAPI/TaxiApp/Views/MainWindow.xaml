<Window x:Class="TaxiApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TaxiApp.ViewModels"
        Title="TaxiApp" 
        Height="700" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Стили кнопок меню -->
        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#424242"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,15"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" 
                                BorderThickness="3,0,0,0" BorderBrush="Transparent">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFF8E1"/>
                    <Setter Property="Foreground" Value="#FF6F00"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#FFC107"/>
            <Setter Property="Foreground" Value="#212121"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFB300"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Боковое меню -->
        <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="80"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Логотип -->
                <Border Grid.Row="0" Background="#FFC107" Padding="20,0">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="🚖 TaxiApp" FontSize="22" FontWeight="Bold" Foreground="#212121"/>
                        <TextBlock Text="{Binding CurrentUserRole, StringFormat='Роль: {0}'}" 
                                   FontSize="12" Foreground="#424242"/>
                    </StackPanel>
                </Border>

                <!-- 🔥 МЕНЮ С ФИЛЬТРАЦИЕЙ ПО РОЛЯМ -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,20,0,0">

                        <!-- ОБЩИЙ ПУНКТ -->
                        <Button Content="👤 Профиль" 
                                Style="{StaticResource MenuButton}"
                                Command="{Binding NavigateCommand}" CommandParameter="Profile"/>

                        <!-- ТОЛЬКО ДЛЯ КЛИЕНТА -->
                        <Button Content="🗺 Создать заказ" 
                                Style="{StaticResource MenuButton}"
                                Visibility="{Binding IsClient, Converter={StaticResource BoolToVis}}"
                                Command="{Binding NavigateCommand}" CommandParameter="Order"/>

                        <Button Content="📋 История поездок" 
                                Style="{StaticResource MenuButton}"
                                Visibility="{Binding IsClient, Converter={StaticResource BoolToVis}}"
                                Command="{Binding NavigateCommand}" CommandParameter="History"/>

                        <Button Content="⭐ Мои отзывы" 
                                Style="{StaticResource MenuButton}"
                                Visibility="{Binding IsClient, Converter={StaticResource BoolToVis}}"
                                Command="{Binding NavigateCommand}" CommandParameter="Reviews"/>

                        <!-- ТОЛЬКО ДЛЯ ВОДИТЕЛЯ -->
                        <Button Content="📋 Взять заказ" 
                                Style="{StaticResource MenuButton}"
                                Visibility="{Binding IsDriver, Converter={StaticResource BoolToVis}}"
                                Command="{Binding NavigateCommand}" CommandParameter="DriverOrders"/>

                        <Button Content="🚗 Активный заказ" 
                                Style="{StaticResource MenuButton}"
                                Visibility="{Binding IsDriver, Converter={StaticResource BoolToVis}}"
                                Command="{Binding NavigateCommand}" CommandParameter="DriverActiveOrder"/>

                        <Button Content="💰 Доход" 
                                Style="{StaticResource MenuButton}"
                                Visibility="{Binding IsDriver, Converter={StaticResource BoolToVis}}"
                                Command="{Binding NavigateCommand}" CommandParameter="DriverEarnings"/>
                        <!-- ТОЛЬКО ДЛЯ Админа -->
                        <Button Content="💵 Тарифы" 
                                Style="{StaticResource MenuButton}"
                                Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVis}}"
                                Command="{Binding NavigateCommand}" CommandParameter="AdminTariffs"/>

                        <Button Content="👥 Пользователи" 
                                Style="{StaticResource MenuButton}"
                                Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVis}}"
                                Command="{Binding NavigateCommand}" CommandParameter="AdminUsers"/>

                        <Button Content="📋 Заказы" 
                                Style="{StaticResource MenuButton}"
                                Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVis}}"
                                Command="{Binding NavigateCommand}" CommandParameter="AdminOrders"/>

                        <Button Content="🚗 Поездки" 
                                Style="{StaticResource MenuButton}"
                                Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVis}}"
                                Command="{Binding NavigateCommand}" CommandParameter="AdminTrips"/>

                    </StackPanel>
                </ScrollViewer>

                <!-- Кнопка выхода -->
                <Border Grid.Row="2" Padding="20" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
                    <Button Content="🚪 Выйти" 
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding LogoutCommand}"
                            HorizontalAlignment="Stretch"/>
                </Border>
            </Grid>
        </Border>

        <!-- Контент -->
        <ContentControl Grid.Column="1" Margin="20" Content="{Binding CurrentPage}"/>
    </Grid>
</Window>